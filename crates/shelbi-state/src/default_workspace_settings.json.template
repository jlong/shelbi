{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".shelbi/hooks/claude.session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/claude.pane-idle" }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".shelbi/hooks/claude.stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/claude.pane-blocked" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/claude.pane-working" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/claude.pane-working" }
        ]
      }
    ]
  }
}
