{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".shelbi/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/pane-idle.sh" }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".shelbi/hooks/stop.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/pane-blocked.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/pane-working.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": ".shelbi/hooks/pane-working.sh" }
        ]
      }
    ]
  }
}
